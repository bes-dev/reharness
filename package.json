{
  "name": "reharness",
  "version": "0.3.0",
  "description": "Deterministic multi-agent pipeline framework with self-evolving harness",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./meta": {
      "types": "./dist/meta/index.d.ts",
      "default": "./dist/meta/index.js"
    }
  },
  "bin": {
    "reharness": "dist/cli.js",
    "reharness-mcp": "dist/integrations/mcp-server.js"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/meta/agents dist/meta/references && cp -r src/meta/agents dist/meta/agents && cp -r src/meta/references dist/meta/references && chmod +x dist/cli.js dist/integrations/mcp-server.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "integrations",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@mariozechner/pi-tui": "^0.70.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
